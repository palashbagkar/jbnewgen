# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# claude code — personal/local overrides (keep committed settings.json shared)
.claude/settings.local.json

# typescript
*.tsbuildinfo
next-env.d.ts

# graphify skill artifacts
graphify-out/
src/graphify-out/

# payload local media uploads (dev only; prod uses Vercel Blob)
/media
